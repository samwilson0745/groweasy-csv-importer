# Server
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# AI Provider: "gemini" | "anthropic" | "openai"
AI_PROVIDER=gemini

# Gemini (default provider - gemini-2.5-flash has a free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (only needed if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Max output tokens per Anthropic call. Raise this (or lower AI_BATCH_SIZE) if
# you see "response was truncated" errors in the logs for large/verbose rows.
ANTHROPIC_MAX_TOKENS=8192

# OpenAI (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Batch processing
AI_BATCH_SIZE=25
AI_MAX_RETRIES=3
# Backoff between retries (ms) after a retryable failure (rate limit, momentary
# provider overload/5xx, timeout) - exponential: AI_RETRY_BASE_MS * 2^attempt,
# capped at AI_RETRY_MAX_DELAY_MS, plus a little jitter. Non-retryable failures
# (bad API key, a response that would truncate identically every time) skip
# retries entirely rather than waiting on a guaranteed repeat failure.
AI_RETRY_BASE_MS=1500
AI_RETRY_MAX_DELAY_MS=10000
# Max batches sent to the AI provider at the same time. Keep this low on
# free-tier API keys (which have low requests-per-minute limits) - a large
# CSV split into many batches will otherwise fire them all at once and get
# rate-limited.
AI_MAX_CONCURRENT_BATCHES=5
# Per-request timeout (ms) to the AI provider - a stuck request fails fast
# and goes through the normal retry path instead of hanging the import.
AI_TIMEOUT_MS=45000
# Server-side backstop timeout (ms) for the whole /api/import/confirm
# request. If processing runs longer than this, the client gets a clean
# JSON 504 and the connection is closed - instead of hanging indefinitely.
# The frontend has its own (usually shorter) NEXT_PUBLIC_API_TIMEOUT_MS and
# gives up first in normal use; this mainly protects direct API callers.
IMPORT_ROUTE_TIMEOUT_MS=150000
